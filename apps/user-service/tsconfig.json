{
  // Visit https://aka.ms/tsconfig to read more about this file
  "extends": "@repo/typescript-config/base.json",
  "compilerOptions": {
    // File Layout
    "rootDir": "./src",
    "outDir": "./dist",

    // Environment Settings
    // See also https://aka.ms/tsconfig/module
    "module": "nodenext",
    "target": "esnext",
    "types": ["node"],
    // For nodejs:
    // "lib": ["esnext"],
    // "types": ["node"],
    // and npm install -D @types/node

    // Other Outputs
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    // Stricter Typechecking Options
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    // Style Options
    // "noImplicitReturns": true,
    // "noImplicitOverride": true,
    // "noUnusedLocals": true,
    // "noUnusedParameters": true,
    // "noFallthroughCasesInSwitch": true,
    // "noPropertyAccessFromIndexSignature": true,

    // Recommended Options
    "paths": {
      "@config/*": ["./src/config/*"],
      "@config": ["./src/config/index.js"],
      "@container/*": ["./src/container/*"],
      "@container": ["./src/container/index.js"],
      "@routes/*": ["./src/api/v1/routes/*"],
      "@routes": ["./src/api/v1/routes/index.js"],
      "@services/*": ["./src/services/*"],
      "@services": ["./src/services/index.js"],
      "@repository/*": ["./src/repository/*"],
      "@repository": ["./src/repository/index.js"],
      "@controllers/*": ["./src/controllers/*"],
      "@controllers": ["./src/controllers/index.js"],
      "@middleware/*": ["./src/middleware/*"],
      "@middleware": ["./src/middleware/index.js"],
      "@utils/errors": ["./src/utils/errors/index.js"],
      "@dto/auth": ["./src/dto/auth/index.js"],
      "@dto/user": ["./src/dto/user/index.js"],
      "@mappers/*": ["./src/mappers/*"],
      "@mappers": ["./src/mappers/index.js"],
      "@generated/*": ["./src/generated/*"]
    },
    "strict": true,
    "jsx": "react-jsx",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "src/generated/orval",
    "test",
    "prisma.config.ts",
    "vitest.config.ts"
  ]
}
