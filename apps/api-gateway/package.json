{
  "name": "api-gateway",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --import @irctc/telemetry/instrumentation ./src/server.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/server.js",
    "check-types": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@irctc/auth-headers": "workspace:*",
    "@irctc/contracts": "workspace:*",
    "@irctc/errors": "workspace:*",
    "@irctc/http": "workspace:*",
    "@irctc/logger": "workspace:*",
    "@irctc/middleware": "workspace:*",
    "@irctc/ratelimit": "workspace:*",
    "@irctc/resilience": "workspace:*",
    "@irctc/service-identity": "workspace:*",
    "@irctc/telemetry": "workspace:*",
    "@opentelemetry/api": "^1.9.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "http-proxy-middleware": "^3.0.5",
    "ioredis": "^5.11.0",
    "jsonwebtoken": "^9.0.3",
    "zod": "^4.4.3",
    "@t3-oss/env-core": "^0.13.11"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.0.0",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.22.4",
    "vitest": "^3.0.5"
  }
}
